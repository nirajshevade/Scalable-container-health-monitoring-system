# ============================================================
# Environment Configuration — Container Health Monitoring System
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# ============================================================

# ─── Grafana ─────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=Admin@Secure123
GRAFANA_SECRET_KEY=SW2YcwTIb9zpOOhoPsMm
GRAFANA_PORT=3000

# ─── Prometheus ──────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─── Alertmanager ────────────────────────────────────────
ALERTMANAGER_PORT=9093

# ─── cAdvisor ────────────────────────────────────────────
CADVISOR_PORT=8080

# ─── Kafka ───────────────────────────────────────────────
KAFKA_PORT=9092
KAFKA_UI_PORT=8090
KAFKA_UI_USER=admin
KAFKA_UI_PASSWORD=Admin@Kafka123
ZOOKEEPER_PORT=2181

# ─── Elasticsearch ───────────────────────────────────────
ELASTICSEARCH_PORT=9200
ELASTIC_PASSWORD=Elastic@Secure123

# ─── Kibana ──────────────────────────────────────────────
KIBANA_PORT=5601
KIBANA_SYSTEM_PASSWORD=Kibana@Secure123
KIBANA_ENCRYPTION_KEY=somegeneratedsecretkey32charslong

# ─── Logstash ────────────────────────────────────────────
LOGSTASH_BEATS_PORT=5044
LOGSTASH_TCP_PORT=5000
LOGSTASH_UDP_PORT=5000

# ─── Health Monitor ──────────────────────────────────────
HEALTH_MONITOR_PORT=8000
MONITOR_INTERVAL=15
CPU_ALERT_THRESHOLD=85.0
MEMORY_ALERT_THRESHOLD=90.0
RESTART_COUNT_THRESHOLD=5
LOG_LEVEL=INFO

# ─── Nginx ───────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ─── Jenkins ─────────────────────────────────────────────
JENKINS_PORT=8081
JENKINS_AGENT_PORT=50000

# ─── SMTP (for email alerts) ─────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@monitoring.local

# ─── Slack (for slack alerts) ────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#alerts

# ─── PagerDuty (for PagerDuty alerts) ───────────────────
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key
