    {
      "datasource": {"type": "prometheus", "uid": "prometheus-main"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true
          },
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Status"},
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "applyToRow": false,
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {"options": {"running": {"color": "green", "index": 0, "text": "✅ Running"}}, "type": "value"},
                  {"options": {"exited": {"color": "red", "index": 1, "text": "❌ Exited"}}, "type": "value"},
                  {"options": {"paused": {"color": "yellow", "index": 2, "text": "⏸ Paused"}}, "type": "value"}
                ]
              }
            ]
          }
        ]
