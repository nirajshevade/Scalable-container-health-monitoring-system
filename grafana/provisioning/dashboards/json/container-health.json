          "expr": "container_monitor_container_restarts_total",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        }
      ],
      "transformations": [
        {"id": "seriesToColumns", "options": {"byField": "container_name"}},
        {"id": "organize", "options": {"excludeByName": {"Time 1": true, "Time 2": true, "__name__ 1": true, "__name__ 2": true}, "renameByName": {"container_name": "Container", "status": "Status", "Value #B": "Restarts"}}}
