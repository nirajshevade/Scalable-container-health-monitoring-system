<?xml version='1.1' encoding='UTF-8'?>
<!--
  Jenkins Pipeline job definition for the Container Health Monitor.
  Place this file in jenkins/jobs/health-monitor-pipeline/config.xml
  and it will be auto-imported via the jobs volume mount.
-->
<flow-definition plugin="workflow-job">
  <description>CI/CD pipeline for the health-monitor service</description>

  <keepDependencies>false</keepDependencies>

  <properties>
    <!-- Discard old builds: keep last 10 -->
    <jenkins.model.BuildDiscarderProperty>
      <strategy class="hudson.tasks.LogRotator">
        <daysToKeep>30</daysToKeep>
        <numToKeep>10</numToKeep>
        <artifactDaysToKeep>-1</artifactDaysToKeep>
        <artifactNumToKeep>-1</artifactNumToKeep>
      </strategy>
    </jenkins.model.BuildDiscarderProperty>

    <!-- Do not allow concurrent builds -->
    <org.jenkinsci.plugins.workflow.job.properties.DisableConcurrentBuildsJobProperty/>

    <!-- Build parameters -->
    <hudson.model.ParametersDefinitionProperty>
      <parameterDefinitions>
        <hudson.model.StringParameterDefinition>
          <name>DOCKER_TAG</name>
          <defaultValue>latest</defaultValue>
          <description>Docker image tag to build and push</description>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.ChoiceParameterDefinition>
          <name>DEPLOY_ENV</name>
          <choices class="java.util.Arrays$ArrayList">
            <a class="string-array">
              <string>staging</string>
              <string>production</string>
            </a>
          </choices>
          <description>Target deployment environment</description>
        </hudson.model.ChoiceParameterDefinition>
        <hudson.model.BooleanParameterDefinition>
          <name>SKIP_TESTS</name>
          <defaultValue>false</defaultValue>
          <description>Skip unit tests (emergency deployments only)</description>
        </hudson.model.BooleanParameterDefinition>
      </parameterDefinitions>
    </hudson.model.ParametersDefinitionProperty>

    <!-- SCM Trigger: poll every 5 minutes -->
    <hudson.triggers.SCMTrigger>
      <spec>H/5 * * * *</spec>
      <ignorePostCommitHooks>false</ignorePostCommitHooks>
    </hudson.triggers.SCMTrigger>
  </properties>

  <definition class="org.jenkinsci.plugins.workflow.cps.CpsScmFlowDefinition"
               plugin="workflow-cps">
    <scm class="hudson.plugins.git.GitSCM" plugin="git">
      <configVersion>2</configVersion>
      <userRemoteConfigs>
        <hudson.plugins.git.UserRemoteConfig>
          <!-- Update this URL to match your repository -->
          <url>https://github.com/your-org/scalable-container-health-monitoring-system.git</url>
          <credentialsId>github-credentials</credentialsId>
        </hudson.plugins.git.UserRemoteConfig>
      </userRemoteConfigs>
      <branches>
        <hudson.plugins.git.BranchSpec>
          <name>*/main</name>
        </hudson.plugins.git.BranchSpec>
      </branches>
      <doGenerateSubmoduleConfigurations>false</doGenerateSubmoduleConfigurations>
      <gitTool>Default</gitTool>
    </scm>
    <!-- Points to the Jenkinsfile in the repo root -->
    <scriptPath>Jenkinsfile</scriptPath>
    <lightweight>true</lightweight>
  </definition>

  <triggers/>
  <disabled>false</disabled>
</flow-definition>
